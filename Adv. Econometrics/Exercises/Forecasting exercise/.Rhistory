library(readr)
sp500_monthly_returns <- read_csv("Data/sp500_monthly_returns.csv")
View(sp500_monthly_returns)
## manual
n <- length(sp500_monthly_returns$log_return)
y <- sp500_monthly_returns$log_return[3:n]
x <- cbind(1,sp500_monthly_returns$log_return[2:(n-1)], sp500_monthly_returns$log_return[1:(n-2)])
View(x)
beta_hat <- solve((t(x)%*%x) %*% (t(x)%*%y))
(t(x)%*%x)
t(x)
beta_hat <- solve(t(x) %*% x) %*% (t(x)%*%y)
View(beta_hat)
resid <- y - x %*% beta_hat
sigma2_hat <- sum(resid^2)/(length(y)-ncol(x))
View(beta_hat)
